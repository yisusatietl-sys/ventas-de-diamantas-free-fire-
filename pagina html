<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>🎮 DIAMANTES FF + SEGUIDORES IG/TIKTOK 🔥</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #0a0a1a;
            color: #f0eef7;
            font-family: 'Rajdhani', sans-serif;
            min-height: 100vh;
            padding: 10px;
            background-image: 
                repeating-linear-gradient(45deg, rgba(156, 39, 176, 0.08) 0px, rgba(156, 39, 176, 0.08) 2px, transparent 2px, transparent 10px),
                radial-gradient(circle at 20% 30%, rgba(255, 0, 128, 0.12) 0%, transparent 40%),
                radial-gradient(circle at 80% 70%, rgba(0, 255, 200, 0.08) 0%, transparent 40%);
            position: relative;
        }
        
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" opacity="0.08"><path d="M20 20 L30 20 L25 30 Z" fill="%23ff44cc"/><path d="M70 60 L80 60 L75 70 Z" fill="%2300ffcc"/><circle cx="50" cy="40" r="5" fill="%23aa44ff"/></svg>');
            pointer-events: none;
            z-index: 0;
            animation: bgMove 35s linear infinite;
        }
        
        @keyframes bgMove {
            0% { background-position: 0 0; }
            100% { background-position: 250px 250px; }
        }
        
        .container {
            max-width: 100%;
            position: relative;
            z-index: 1;
        }
        
        /* HEADER GAMER - BORDES CAMBIANTES MULTICOLOR */
        .gamer-header {
            text-align: center;
            padding: 25px 15px 15px 15px;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #0d0b1a, #12102a, #0f0d24);
            border-radius: 20px;
            border: 3px solid transparent;
            background-clip: padding-box;
            box-shadow: 0 0 30px rgba(255, 68, 204, 0.6), inset 0 0 15px rgba(0, 255, 204, 0.3);
            position: relative;
            overflow: hidden;
            animation: borderPulseRGB 1.5s infinite alternate;
        }
        
        .gamer-header::before {
            content: "";
            position: absolute;
            top: -3px;
            left: -3px;
            right: -3px;
            bottom: -3px;
            background: linear-gradient(90deg, #ff44cc, #aa44ff, #00ffcc, #ffcc44, #ff44cc, #aa44ff);
            background-size: 400% 400%;
            border-radius: 20px;
            z-index: -1;
            animation: borderRotateRGB 2s linear infinite;
        }
        
        @keyframes borderRotateRGB {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 200% 50%; }
        }
        
        @keyframes borderPulseRGB {
            0% { box-shadow: 0 0 20px #ff44cc, inset 0 0 10px rgba(255,68,204,0.3); }
            33% { box-shadow: 0 0 40px #aa44ff, inset 0 0 20px rgba(170,68,255,0.4); }
            66% { box-shadow: 0 0 35px #00ffcc, inset 0 0 20px rgba(0,255,204,0.4); }
            100% { box-shadow: 0 0 45px #ffcc44, inset 0 0 25px rgba(255,204,68,0.4); }
        }
        
        .gamer-header::after {
            content: "FF";
            position: absolute;
            bottom: -20px;
            right: -20px;
            font-size: 8rem;
            font-weight: 900;
            color: rgba(255, 68, 204, 0.05);
            font-family: 'Orbitron', sans-serif;
            transform: rotate(-15deg);
            pointer-events: none;
        }
        
        .gamer-title {
            font-size: 2.2rem;
            font-weight: 900;
            margin-bottom: 5px;
            color: #f0eef7;
            text-shadow: 0 0 12px #ff44cc, 0 0 25px #aa44ff, 0 0 40px #00ffcc;
            letter-spacing: 3px;
            font-family: 'Orbitron', sans-serif;
            animation: textFlickerRGB 2s infinite;
        }
        
        @keyframes textFlickerRGB {
            0% { text-shadow: 0 0 10px #ff44cc, 0 0 20px #aa44ff; }
            25% { text-shadow: 0 0 15px #aa44ff, 0 0 30px #00ffcc; }
            50% { text-shadow: 0 0 10px #00ffcc, 0 0 35px #ffcc44; }
            75% { text-shadow: 0 0 18px #ffcc44, 0 0 28px #ff44cc; }
            100% { text-shadow: 0 0 10px #ff44cc, 0 0 20px #00ffcc; }
        }
        
        .gamer-subtitle {
            font-size: 1.2rem;
            color: #ffcc44;
            font-weight: 700;
            text-transform: uppercase;
            background: linear-gradient(90deg, transparent, rgba(255,68,204,0.25), transparent);
            padding: 8px;
            border-radius: 30px;
            letter-spacing: 2px;
            margin-bottom: 20px;
            text-shadow: 0 0 8px #ff44cc;
            animation: subtitleGlow 2s infinite alternate;
        }
        
        @keyframes subtitleGlow {
            0% { color: #ffcc44; text-shadow: 0 0 5px #ffcc44; }
            50% { color: #ff44cc; text-shadow: 0 0 12px #ff44cc; }
            100% { color: #00ffcc; text-shadow: 0 0 8px #00ffcc; }
        }

        /* CALENDARIO DE ATENCIÓN - colores cambiantes */
        .schedule-container {
            background: rgba(13, 11, 26, 0.9);
            border-radius: 20px;
            padding: 15px 20px;
            margin: 0 10px 20px 10px;
            backdrop-filter: blur(5px);
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            gap: 20px;
            font-family: 'Orbitron', sans-serif;
            animation: scheduleBorderGlow 1.8s infinite alternate;
        }
        
        @keyframes scheduleBorderGlow {
            0% { border: 2px solid #ff44cc; box-shadow: 0 0 15px #ff44cc; }
            33% { border: 2px solid #aa44ff; box-shadow: 0 0 25px #aa44ff; }
            66% { border: 2px solid #00ffcc; box-shadow: 0 0 30px #00ffcc; }
            100% { border: 2px solid #ffcc44; box-shadow: 0 0 20px #ffcc44; }
        }

        .schedule-item {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 68, 204, 0.15);
            padding: 8px 15px;
            border-radius: 40px;
            animation: scheduleItemBorder 2s infinite alternate;
        }
        
        @keyframes scheduleItemBorder {
            0% { border: 1px solid #ff44cc; box-shadow: 0 0 5px #ff44cc; }
            50% { border: 1px solid #aa44ff; box-shadow: 0 0 12px #aa44ff; }
            100% { border: 1px solid #00ffcc; box-shadow: 0 0 8px #00ffcc; }
        }

        .schedule-item i {
            color: #ffcc44;
            font-size: 1.2rem;
            filter: drop-shadow(0 0 6px #ffcc44);
            animation: iconColor 1.5s infinite alternate;
        }
        
        @keyframes iconColor {
            0% { color: #ffcc44; filter: drop-shadow(0 0 4px #ffcc44); }
            50% { color: #ff44cc; filter: drop-shadow(0 0 8px #ff44cc); }
            100% { color: #00ffcc; filter: drop-shadow(0 0 6px #00ffcc); }
        }

        .schedule-item span {
            color: #f0eef7;
            font-weight: 600;
            font-size: 0.95rem;
        }

        .schedule-item .days {
            font-weight: 900;
            margin-right: 5px;
            animation: daysColor 1.8s infinite alternate;
        }
        
        @keyframes daysColor {
            0% { color: #ffcc44; text-shadow: 0 0 3px #ffcc44; }
            50% { color: #ff44cc; text-shadow: 0 0 6px #ff44cc; }
            100% { color: #00ffcc; text-shadow: 0 0 5px #00ffcc; }
        }

        .schedule-highlight {
            background: linear-gradient(45deg, #ff44cc, #aa44ff);
            padding: 8px 20px;
            border-radius: 40px;
            border: 2px solid #ffffff;
            font-weight: 900;
            color: #ffffff;
            letter-spacing: 1px;
            animation: highlightPulse 1.2s infinite alternate;
        }
        
        @keyframes highlightPulse {
            0% { box-shadow: 0 0 10px #ff44cc; background: linear-gradient(45deg, #ff44cc, #aa44ff); }
            50% { box-shadow: 0 0 25px #00ffcc; background: linear-gradient(45deg, #aa44ff, #00ffcc); }
            100% { box-shadow: 0 0 20px #ffcc44; background: linear-gradient(45deg, #ffcc44, #ff44cc); }
        }

        .schedule-highlight i {
            margin-right: 8px;
            color: #ffffff;
        }
        
        /* BOTONES PRINCIPALES */
        .contact-buttons {
            display: flex;
            justify-content: center;
            margin: 25px 0;
            gap: 20px;
            flex-wrap: wrap;
        }
        
        .gamer-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            padding: 18px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1.3rem;
            transition: all 0.3s;
            text-align: center;
            border: 2px solid;
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
            position: relative;
            overflow: hidden;
        }
        
        .gamer-btn::before {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 200%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }
        
        .gamer-btn:hover::before {
            left: 100%;
        }
        
        .whatsapp-btn {
            background: linear-gradient(45deg, #25D366, #128C7E);
            color: #ffffff;
            border-color: #ffffff;
            box-shadow: 0 0 20px #25D366, 0 0 40px #128C7E;
        }
        
        .channel-btn {
            background: linear-gradient(45deg, #ff44cc, #aa44ff);
            color: #ffffff;
            border-color: #ffffff;
            animation: channelBtnGradient 2s infinite alternate;
        }
        
        @keyframes channelBtnGradient {
            0% { background: linear-gradient(45deg, #ff44cc, #aa44ff); box-shadow: 0 0 20px #ff44cc; }
            50% { background: linear-gradient(45deg, #aa44ff, #00ffcc); box-shadow: 0 0 30px #aa44ff; }
            100% { background: linear-gradient(45deg, #00ffcc, #ffcc44); box-shadow: 0 0 25px #00ffcc; }
        }
        
        .whatsapp-btn:hover, .channel-btn:hover {
            transform: scale(1.05) translateY(-5px);
            box-shadow: 0 0 40px #ffffff, 0 0 70px #ff44cc;
        }
        
        .id-display {
            background: rgba(13, 11, 26, 0.9);
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            margin: 20px 0;
            font-weight: 700;
            font-size: 1.3rem;
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 2px;
            backdrop-filter: blur(5px);
            animation: idBorderColor 1.5s infinite alternate;
        }
        
        @keyframes idBorderColor {
            0% { border: 3px solid #ffcc44; box-shadow: 0 0 20px #ffcc44; color: #ffcc44; }
            25% { border: 3px solid #ff44cc; box-shadow: 0 0 25px #ff44cc; color: #ff44cc; }
            50% { border: 3px solid #aa44ff; box-shadow: 0 0 30px #aa44ff; color: #aa44ff; }
            75% { border: 3px solid #00ffcc; box-shadow: 0 0 25px #00ffcc; color: #00ffcc; }
            100% { border: 3px solid #ffcc44; box-shadow: 0 0 20px #ffcc44; color: #ffcc44; }
        }
        
        /* SCROLL HORIZONTAL */
        .section-container {
            margin-bottom: 40px;
        }
        
        .section-title {
            font-size: 1.8rem;
            color: #ffffff;
            margin-bottom: 20px;
            padding-left: 15px;
            font-weight: 900;
            display: flex;
            align-items: center;
            gap: 15px;
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
            background: linear-gradient(90deg, rgba(255, 68, 204, 0.2), transparent);
            padding: 10px 15px;
            border-radius: 0 30px 30px 0;
            animation: titleBorderGlow 1.8s infinite alternate;
        }
        
        @keyframes titleBorderGlow {
            0% { border-left: 6px solid #ff44cc; text-shadow: 0 0 8px #ff44cc; }
            33% { border-left: 6px solid #aa44ff; text-shadow: 0 0 15px #aa44ff; }
            66% { border-left: 6px solid #00ffcc; text-shadow: 0 0 12px #00ffcc; }
            100% { border-left: 6px solid #ffcc44; text-shadow: 0 0 10px #ffcc44; }
        }
        
        .products-scroll {
            display: flex;
            overflow-x: auto;
            gap: 20px;
            padding: 15px 10px;
            scrollbar-width: thin;
            scrollbar-color: #ff44cc #0a0a1a;
            scroll-behavior: smooth;
        }
        
        .products-scroll::-webkit-scrollbar {
            height: 10px;
        }
        
        .products-scroll::-webkit-scrollbar-track {
            background: #0a0a1a;
            border-radius: 10px;
            animation: scrollTrackColor 2s infinite alternate;
        }
        
        @keyframes scrollTrackColor {
            0% { border: 1px solid #ff44cc; }
            50% { border: 1px solid #aa44ff; }
            100% { border: 1px solid #00ffcc; }
        }
        
        .products-scroll::-webkit-scrollbar-thumb {
            background: linear-gradient(45deg, #ff44cc, #aa44ff, #00ffcc, #ffcc44);
            background-size: 300% 300%;
            border-radius: 10px;
            animation: thumbGradient 2s infinite alternate;
        }
        
        @keyframes thumbGradient {
            0% { background-position: 0% 50%; }
            100% { background-position: 100% 50%; }
        }
        
        /* TARJETAS - bordes RGB cambiantes */
        .product-card {
            min-width: 300px;
            background: rgba(10, 8, 22, 0.95);
            border-radius: 20px;
            overflow: hidden;
            flex-shrink: 0;
            border: 2px solid transparent;
            transition: all 0.4s;
            position: relative;
            backdrop-filter: blur(8px);
            animation: cardBorderAnim 2s infinite alternate;
        }
        
        @keyframes cardBorderAnim {
            0% { box-shadow: 0 0 15px #ff44cc; }
            33% { box-shadow: 0 0 25px #aa44ff; }
            66% { box-shadow: 0 0 20px #00ffcc; }
            100% { box-shadow: 0 0 30px #ffcc44; }
        }
        
        .product-card::before {
            content: "";
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #ff44cc, #aa44ff, #00ffcc, #ffcc44, #ff44cc);
            background-size: 400% 400%;
            border-radius: 20px;
            z-index: -1;
            animation: rainbowNeon 1.8s ease infinite;
            opacity: 0;
            transition: opacity 0.4s;
        }
        
        @keyframes rainbowNeon {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 200% 50%; }
        }
        
        .product-card:hover::before {
            opacity: 1;
        }
        
        .product-card:hover {
            transform: translateY(-8px) scale(1.02);
        }
        
        .product-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background: linear-gradient(45deg, #ff44cc, #aa44ff);
            color: white;
            padding: 8px 15px;
            border-radius: 30px;
            font-size: 0.9rem;
            font-weight: 900;
            z-index: 2;
            border: 1px solid #ffffff;
            text-transform: uppercase;
            font-family: 'Orbitron', sans-serif;
            animation: badgeGradient 1.5s infinite alternate;
        }
        
        @keyframes badgeGradient {
            0% { background: linear-gradient(45deg, #ff44cc, #aa44ff); box-shadow: 0 0 10px #ff44cc; }
            50% { background: linear-gradient(45deg, #aa44ff, #00ffcc); box-shadow: 0 0 15px #aa44ff; }
            100% { background: linear-gradient(45deg, #00ffcc, #ffcc44); box-shadow: 0 0 12px #00ffcc; }
        }
        
        .product-image {
            width: 100%;
            height: 180px;
            object-fit: cover;
            transition: transform 0.5s;
            animation: imageBorder 2s infinite alternate;
        }
        
        @keyframes imageBorder {
            0% { border-bottom: 4px solid #ff44cc; }
            33% { border-bottom: 4px solid #aa44ff; }
            66% { border-bottom: 4px solid #00ffcc; }
            100% { border-bottom: 4px solid #ffcc44; }
        }
        
        .product-card:hover .product-image {
            transform: scale(1.03);
        }
        
        .product-content {
            padding: 20px;
            background: linear-gradient(180deg, rgba(20, 15, 40, 0.95), rgba(8, 6, 20, 0.98));
        }
        
        .diamond-info {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
        }
        
        .diamond-icon {
            font-size: 2rem;
            animation: diamondIconColor 1.5s infinite alternate;
        }
        
        @keyframes diamondIconColor {
            0% { color: #ffcc44; filter: drop-shadow(0 0 5px #ffcc44); }
            50% { color: #ff44cc; filter: drop-shadow(0 0 8px #ff44cc); }
            100% { color: #00ffcc; filter: drop-shadow(0 0 6px #00ffcc); }
        }
        
        .diamond-count {
            font-size: 1.5rem;
            font-weight: 900;
            font-family: 'Orbitron', sans-serif;
            animation: countColor 1.8s infinite alternate;
        }
        
        @keyframes countColor {
            0% { color: #ffcc44; text-shadow: 0 0 5px #ffcc44; }
            50% { color: #ff44cc; text-shadow: 0 0 8px #ff44cc; }
            100% { color: #00ffcc; text-shadow: 0 0 6px #00ffcc; }
        }
        
        .price-container {
            display: flex;
            align-items: baseline;
            gap: 5px;
            margin-bottom: 20px;
            background: rgba(255, 68, 204, 0.1);
            padding: 10px;
            border-radius: 10px;
            animation: priceBorder 1.5s infinite alternate;
        }
        
        @keyframes priceBorder {
            0% { border: 1px solid #ff44cc; }
            50% { border: 1px solid #aa44ff; }
            100% { border: 1px solid #00ffcc; }
        }
        
        .price {
            font-size: 2.2rem;
            font-weight: 900;
            animation: priceColor 1.5s infinite alternate;
        }
        
        @keyframes priceColor {
            0% { color: #00ffcc; text-shadow: 0 0 8px #00ffcc; }
            50% { color: #ffcc44; text-shadow: 0 0 10px #ffcc44; }
            100% { color: #ff44cc; text-shadow: 0 0 8px #ff44cc; }
        }
        
        .price small {
            font-size: 1rem;
            color: #f0eef7;
            opacity: 0.9;
        }
        
        /* BOTÓN COMPRAR - mantiene estilo pero con animación de colores */
        .gamer-button {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 10px;
            font-weight: 900;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 2px;
            text-transform: uppercase;
            position: relative;
            overflow: hidden;
            border: 1px solid #ffffff;
            z-index: 1;
            animation: buttonGradientAnim 2s infinite alternate;
        }
        
        @keyframes buttonGradientAnim {
            0% { background: linear-gradient(45deg, #ff44cc, #aa44ff); box-shadow: 0 0 15px #ff44cc; }
            50% { background: linear-gradient(45deg, #aa44ff, #00ffcc); box-shadow: 0 0 20px #aa44ff; }
            100% { background: linear-gradient(45deg, #00ffcc, #ffcc44); box-shadow: 0 0 18px #00ffcc; }
        }
        
        .gamer-button::before {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 300%;
            height: 100%;
            background: linear-gradient(
                90deg,
                transparent,
                rgba(255, 255, 255, 0.4),
                rgba(255, 255, 255, 0.8),
                rgba(255, 255, 255, 0.4),
                transparent
            );
            transform: skewX(-25deg);
            transition: left 0.5s;
            z-index: -1;
        }
        
        .gamer-button.animating-colors {
            animation: colorWaveNeon 1s ease infinite;
            background-size: 300% 300%;
            border: 2px solid #ffffff;
            box-shadow: 0 0 30px #ffffff, 0 0 50px #ff44cc;
        }
        
        @keyframes colorWaveNeon {
            0% {
                background: linear-gradient(45deg, #ff44cc, #aa44ff, #00ffcc, #ffcc44);
                background-size: 300% 300%;
                background-position: 0% 50%;
            }
            50% {
                background: linear-gradient(45deg, #aa44ff, #00ffcc, #ffcc44, #ff44cc);
                background-size: 300% 300%;
                background-position: 100% 50%;
            }
            100% {
                background: linear-gradient(45deg, #00ffcc, #ffcc44, #ff44cc, #aa44ff);
                background-size: 300% 300%;
                background-position: 200% 50%;
            }
        }
        
        .gamer-button:hover::before {
            left: 100%;
        }
        
        .gamer-button:hover {
            transform: scale(1.02);
            letter-spacing: 4px;
        }
        
        /* BOTÓN FLOTANTE */
        .floating-button {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 100;
        }
        
        .floating-button a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            font-size: 3rem;
            text-decoration: none;
            border: 3px solid #ffffff;
            transition: all 0.4s;
            animation: floatBtnColor 1.2s infinite alternate;
        }
        
        @keyframes floatBtnColor {
            0% { background: linear-gradient(135deg, #ff44cc, #aa44ff); box-shadow: 0 0 25px #ff44cc; }
            33% { background: linear-gradient(135deg, #aa44ff, #00ffcc); box-shadow: 0 0 35px #aa44ff; }
            66% { background: linear-gradient(135deg, #00ffcc, #ffcc44); box-shadow: 0 0 30px #00ffcc; }
            100% { background: linear-gradient(135deg, #ffcc44, #ff44cc); box-shadow: 0 0 40px #ffcc44; }
        }
        
        .floating-button a:hover {
            transform: scale(1.2) rotate(5deg);
            box-shadow: 0 0 80px #ffffff;
        }
        
        footer {
            text-align: center;
            padding: 30px 15px;
            margin-top: 40px;
            background: rgba(10, 8, 22, 0.96);
            border-radius: 30px 30px 0 0;
            backdrop-filter: blur(8px);
            animation: footerBorder 2s infinite alternate;
        }
        
        @keyframes footerBorder {
            0% { border-top: 4px solid #ff44cc; box-shadow: 0 -10px 30px rgba(255,68,204,0.3); }
